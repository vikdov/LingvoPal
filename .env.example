# LingvoPal/.env
# ============================================================================
# ENVIRONMENT
# ============================================================================
ENV=development
DEBUG=True
LOG_LEVEL=DEBUG

# ============================================================================
# DATABASE
# ============================================================================
DATABASE_USER=lingvopal_user
DATABASE_PASSWORD=secure_password_change_in_production
# CRITICAL DOCKER NOTE:
# If running FastAPI locally (uvicorn) -> use 'localhost'
# If running FastAPI inside docker-compose -> use 'postgres' (or your db service name)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=lingvopal_db

DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ============================================================================
# BACKEND APPLICATION
# ============================================================================
API_TITLE=LingvoPal
API_VERSION=1.0.0
API_HOST=0.0.0.0
API_PORT=8000

# ============================================================================
# SECURITY
# ============================================================================
SECRET_KEY=dev-secret-key-must-be-32-characters-minimum-12345678
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============================================================================
# CORS
# ============================================================================
# Because we added the parse_cors_origins validator, we can just use a clean comma-separated list!
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ============================================================================
# INFRASTRUCTURE (pgAdmin & Redis)
# ============================================================================
PGADMIN_EMAIL=admin@lingvopal.local
PGADMIN_PASSWORD=admin_password_change_this
PGADMIN_PORT=5050

REDIS_HOST=localhost
REDIS_PORT=6379
