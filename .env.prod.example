# LingvoPal/.env.production  (backend)
# ============================================================================
# PRODUCTION TEMPLATE — free-tier multi-PaaS deployment.
#
# This file documents the production deployment surface. The real values are
# NOT committed: they live in the Render dashboard (runtime env) and in GitHub
# Secrets (consumed by .github/workflows/cd.yml for the migration job). Copy
# the keys, fill them in the platform, never commit the filled file.
# ============================================================================

# ----------------------------------------------------------------------------
# ENVIRONMENT
# ----------------------------------------------------------------------------
ENV=production
DEBUG=False
LOG_LEVEL=INFO

# ----------------------------------------------------------------------------
# DATABASE — Neon (managed Postgres). Use the POOLED connection endpoint.
# Neon enforces TLS; the async (asyncpg) engine needs DATABASE_SSL=true.
# ----------------------------------------------------------------------------
DATABASE_USER=<neon-user>
DATABASE_PASSWORD=<neon-password>
DATABASE_HOST=<project>-pooler.<region>.aws.neon.tech
DATABASE_PORT=5432
DATABASE_NAME=<neon-db>
DATABASE_SSL=true

DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ----------------------------------------------------------------------------
# BACKEND APPLICATION
# ----------------------------------------------------------------------------
API_TITLE=LingvoPal
API_VERSION=1.0.0
API_HOST=0.0.0.0
API_PORT=8000

# ----------------------------------------------------------------------------
# SECURITY — generate a fresh 32+ char key; never reuse the dev key.
# ----------------------------------------------------------------------------
SECRET_KEY=<generate-32+-char-secret>
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ----------------------------------------------------------------------------
# CORS — the deployed Vercel frontend origin (no trailing slash).
# ----------------------------------------------------------------------------
CORS_ORIGINS=["https://<app>.vercel.app"]
FRONTEND_URL=https://<app>.vercel.app

# ----------------------------------------------------------------------------
# REDIS — Upstash (TLS endpoint). REDIS_SSL=true switches the scheme to
# rediss://; REDIS_PASSWORD is the Upstash token. Take host/port/token from the
# Upstash connection details (NOT the full URL — the app assembles it).
# ----------------------------------------------------------------------------
REDIS_HOST=<id>.upstash.io
REDIS_PORT=6379
REDIS_SSL=true
REDIS_PASSWORD=<upstash-token>

# ----------------------------------------------------------------------------
# OBJECT STORAGE — Cloudflare R2 (S3-compatible).
# S3_SECURE=true makes the endpoint https (no :443); R2 uses region "auto".
# ----------------------------------------------------------------------------
S3_HOST=<account-id>.r2.cloudflarestorage.com
S3_PORT=443
S3_SECURE=true
S3_ACCESS_KEY=<r2-access-key-id>
S3_SECRET_KEY=<r2-secret-access-key>
S3_BUCKET=lingvopal
S3_REGION=auto
# Public media URL — R2 public bucket or a custom/CDN domain.
MEDIA_BASE_URL=https://<r2-public-or-cdn-domain>/lingvopal

# ----------------------------------------------------------------------------
# EMAIL — external SMTP provider (Brevo). Enable TLS in production.
# ----------------------------------------------------------------------------
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=<brevo-smtp-user>
SMTP_PASSWORD=<brevo-smtp-key>
SMTP_FROM=noreply@<your-domain>
SMTP_TLS=true

# ----------------------------------------------------------------------------
# THIRD-PARTY KEYS
# ----------------------------------------------------------------------------
AI_API_KEY=<ai-provider-key>
IMAGE_SEARCH_PROVIDER=unsplash
IMAGE_SEARCH_API_KEY=<image-search-key>
TTS_ENABLED=false
