# =============================================================================
# LingvoPal Frontend — Environment Variables
# Copy to .env and adjust for your setup.
# Vite bakes these values into the bundle at build time.
# =============================================================================

# Backend API base URL (no trailing slash)
VITE_API_URL=http://localhost:8000/api/v1

# Display title shown in browser tab / dev tools
VITE_APP_TITLE=LingvoPal (Development)

# Set to true to enable analytics (e.g. Plausible, PostHog)
VITE_ENABLE_ANALYTICS=false

# Show the debug panel overlay in development
VITE_ENABLE_DEBUG_PANEL=true
