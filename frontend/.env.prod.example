# =============================================================================
# LingvoPal Frontend — PRODUCTION template (Vercel build env).
# Set these in the Vercel project settings; Vite bakes them into the bundle at
# build time. Do not commit the filled file.
# =============================================================================

# Render backend base URL (no trailing slash).
VITE_API_URL=https://<backend>.onrender.com/api/v1

# Display title shown in browser tab / dev tools.
VITE_APP_TITLE=LingvoPal

# Analytics off unless a provider is wired.
VITE_ENABLE_ANALYTICS=false

# No debug overlay in production.
VITE_ENABLE_DEBUG_PANEL=false
