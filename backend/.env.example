# =============================================================================
# LingvoPal Backend — Environment Variables (baseline / local dev)
# Copy to .env and fill in the values.
# No Docker required — all services run locally.
# =============================================================================

# ---------------------------------------------------------------------------
# Environment
# ---------------------------------------------------------------------------
ENV=development

# ---------------------------------------------------------------------------
# Database (PostgreSQL — running locally via systemctl)
# ---------------------------------------------------------------------------
DATABASE_USER=lingvopal
DATABASE_PASSWORD=changeme
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=lingvopal

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
DEBUG=false
LOG_LEVEL=INFO

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=replace-me-with-a-random-32-char-minimum-secret-key

ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173

# ---------------------------------------------------------------------------
# Redis (running locally via systemctl)
# ---------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# Email / SMTP
# Dev: emails logged to console; no real SMTP server required.
# ---------------------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@lingvopal.com
SMTP_TLS=false
FRONTEND_URL=http://localhost:5173

# ---------------------------------------------------------------------------
# Object Storage (S3-compatible)
# S3 features non-functional without a running MinIO instance.
# App starts and core features work without it.
# ---------------------------------------------------------------------------
S3_HOST=localhost
S3_PORT=9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=lingvopal
S3_REGION=us-east-1
MEDIA_BASE_URL=http://localhost:9000/lingvopal

# ---------------------------------------------------------------------------
# AI / LLM (item suggestions)
# Set a real key to use AI features; dummy value disables them gracefully.
# ---------------------------------------------------------------------------
AI_PROVIDER=groq
AI_API_KEY=dummy-not-used
AI_MODEL=llama-3.3-70b-versatile

# ---------------------------------------------------------------------------
# Text-to-Speech
# TTS_ENABLED=false disables TTS entirely — no credentials required.
# ---------------------------------------------------------------------------
TTS_ENABLED=false
TTS_PROVIDER=google_cloud
GOOGLE_APPLICATION_CREDENTIALS=
TTS_API_KEY=
TTS_LANGUAGE_CODE=en-US

# ---------------------------------------------------------------------------
# Image Search
# Set a real key to use image search; dummy value disables it gracefully.
# ---------------------------------------------------------------------------
IMAGE_SEARCH_PROVIDER=unsplash
IMAGE_SEARCH_API_KEY=dummy-not-used
IMAGE_COUNT=1

# ---------------------------------------------------------------------------
# Content Moderation
# ---------------------------------------------------------------------------
COMPLAINT_ESCALATION_THRESHOLD=3
MAX_COMPLAINTS_PER_DAY=5
OFFICIAL_MIN_LEARNERS=20
OFFICIAL_MIN_SUCCESS_RATE=0.70
