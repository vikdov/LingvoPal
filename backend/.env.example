# =============================================================================
# LingvoPal Backend — Environment Variables
# Copy to .env and fill in the values.
# =============================================================================

# ---------------------------------------------------------------------------
# Environment
# ---------------------------------------------------------------------------
ENV=development

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
DATABASE_USER=lingvopal
DATABASE_PASSWORD=changeme
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=lingvopal

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
DEBUG=false
LOG_LEVEL=INFO

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=replace-me-with-a-random-32-char-minimum-secret-key

ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------------------------------------------------------------------------
# CORS
# Comma-separated or JSON array. Add your frontend origin here.
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173

# ---------------------------------------------------------------------------
# Redis
# Use 'redis' when running via docker-compose; 'localhost' for local dev.
# ---------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# Email / SMTP
# Dev default: Mailpit (docker-compose) — catches all email, UI at :8025
# ---------------------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@lingvopal.com
SMTP_TLS=false
FRONTEND_URL=http://localhost:5173

# ---------------------------------------------------------------------------
# Object Storage (MinIO locally / S3-compatible in production)
# Dev: docker-compose spins up MinIO on port 9000 (UI on 9001)
# ---------------------------------------------------------------------------
S3_HOST=localhost
S3_PORT=9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=lingvopal
S3_REGION=us-east-1
MEDIA_BASE_URL=http://localhost:9000/lingvopal

# ---------------------------------------------------------------------------
# AI / LLM (item suggestions)
# AI_PROVIDER: groq | google
# Groq: https://console.groq.com — free tier available
# ---------------------------------------------------------------------------
AI_PROVIDER=groq
AI_API_KEY=
AI_MODEL=llama-3.3-70b-versatile

# ---------------------------------------------------------------------------
# Text-to-Speech
# Set TTS_ENABLED=false to skip credential validation and disable TTS.
#
# google_cloud: set GOOGLE_APPLICATION_CREDENTIALS to the service account JSON
# elevenlabs:   set TTS_API_KEY to your ElevenLabs API key
# ---------------------------------------------------------------------------
TTS_ENABLED=false
TTS_PROVIDER=google_cloud
GOOGLE_APPLICATION_CREDENTIALS=
TTS_API_KEY=
TTS_LANGUAGE_CODE=en-US

# ---------------------------------------------------------------------------
# Image Search
# IMAGE_SEARCH_PROVIDER: unsplash | pexels | pixabay
# ---------------------------------------------------------------------------
IMAGE_SEARCH_PROVIDER=unsplash
IMAGE_SEARCH_API_KEY=
IMAGE_COUNT=1

# ---------------------------------------------------------------------------
# Content Moderation (optional — defaults are usually fine)
# ---------------------------------------------------------------------------
COMPLAINT_ESCALATION_THRESHOLD=3
MAX_COMPLAINTS_PER_DAY=5
OFFICIAL_MIN_LEARNERS=20
OFFICIAL_MIN_SUCCESS_RATE=0.70
